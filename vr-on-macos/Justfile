set shell := ["bash", "-euo", "pipefail", "-c"]

vr_dir := justfile_directory()

default:
  @just --list

# Build everything needed for local iteration (bridge + DLLs).
build:
  cd "{{vr_dir}}/ALVR" && cargo build -p alvr_macos_bridge --release
  cd "{{vr_dir}}/ALVR/alvr/vrclient_macos" && ./build.sh

# Smoke-test: deploy + start bridge (no auto-launch).
smoke GAME BOTTLE:
  cd "{{vr_dir}}/ALVR/alvr/vrclient_macos/build" && ./vr_smoketest.sh --game "{{GAME}}" --bottle "{{BOTTLE}}"

# Smoke-test: deploy + start bridge + auto-launch title.
smoke-launch GAME BOTTLE:
  cd "{{vr_dir}}/ALVR/alvr/vrclient_macos/build" && ./vr_smoketest.sh --game "{{GAME}}" --bottle "{{BOTTLE}}" --launch

# Tail the two most useful logs during a run.
logs BOTTLE:
  echo "== /tmp/alvr_macos_bridge.log ==";
  tail -n 80 /tmp/alvr_macos_bridge.log 2>/dev/null || true;
  echo "";
  echo "== bottle drive_c logs ==";
  tail -n 80 "{{BOTTLE}}/drive_c/alvr_vrclient.log" 2>/dev/null || true;
  tail -n 80 "{{BOTTLE}}/drive_c/alvr_openvr_api.log" 2>/dev/null || true
