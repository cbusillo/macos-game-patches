{
  "defaultBranch": "main",
  "projectType": "macos-game-vr-research-baseline",
  "docs": {
    "overview": "README.md",
    "agentGuidelines": "AGENTS.md",
    "repoMetadata": ".github/github.json",
    "ciWorkflow": ".github/workflows/ci.yml",
    "dependabot": ".github/dependabot.yml",
    "actionlint": ".github/actionlint.yaml",
    "environment": "docs/environment.md",
    "sourceWorkspace": "docs/source-workspace.md",
    "activeOptionBPlan": "docs/option-b-v21-native-bridge-plan.md",
    "probeLedger": "docs/probes/README.md",
    "firstProbe": "docs/probes/001-alvr-v21-visionos-compatibility.md",
    "avpRuntimeGate": "docs/probes/002-alvr-v21-avp-runtime-gate.md",
    "alvrVisionOsPatches": "patches/alvr-visionos/README.md"
  },
  "qualityGate": {
    "json": {
      "metadata": "jq empty .github/github.json"
    },
    "lint": {
      "markdown": "npx --yes markdownlint-cli2 \"README.md\" \"AGENTS.md\" \"docs/*.md\" \"docs/**/*.md\" \"patches/**/*.md\"",
      "workflows": "actionlint -config-file .github/actionlint.yaml .github/workflows/ci.yml",
      "pythonTools": "python3 -m py_compile tools/vr_stack_cleanup.py"
    },
    "security": {
      "secretScan": "gitleaks detect --source . --no-git --redact --verbose",
      "gitleaksVersion": "8.30.1"
    },
    "runtimePreflight": {
      "vrStackCleanup": "python3 tools/vr_stack_cleanup.py"
    },
    "docsRequiredWhen": [
      "new experiment plans are added",
      "validation gates change",
      "primary commands change",
      "hardware/runtime assumptions change",
      "cleanup policy changes",
      "GitHub workflow changes",
      "dependency automation changes"
    ]
  },
  "importantWorkflows": ["CI"],
  "qaLabels": [],
  "deployLabels": [],
  "healthUrls": [],
  "relatedRepos": [
    {
      "name": "alvr-visionos",
      "repo": "alvr-org/alvr-visionos",
      "localPath": "../alvr-visionos",
      "baselineCommit": "301b9285073949033727baab2d556fe9e8620612",
      "purpose": "Apple Vision Pro client source checkout for v21 compatibility probes"
    },
    {
      "name": "ALVR",
      "repo": "alvr-org/ALVR",
      "localPath": "../alvr",
      "baselineCommit": "d9f2b19d2b98b9d70411439fef83300c84ed171d",
      "purpose": "Standalone streamer/server source checkout and v21 client-core reference"
    }
  ],
  "validatedThrough": [],
  "githubSignals": {
    "postMerge": {
      "waitForActions": true,
      "checkSecurityAndQuality": true
    },
    "capabilities": {
      "codeScanning": "not_enabled",
      "secretScanning": "not_enabled",
      "dependabotAlerts": "available",
      "securityAdvisories": "available"
    },
    "refreshWhen": [
      "repo visibility changes",
      "GitHub plan changes",
      "security settings change",
      "token permissions change"
    ]
  },
  "cleanup": {
    "deleteMergedLocalBranches": true,
    "removeMergedCleanWorktrees": true
  },
  "metadataFreshness": {
    "updateWhen": [
      "docs routing changes",
      "validation gates change",
      "primary commands change",
      "important workflows change",
      "repo relationship changes",
      "cleanup policy changes",
      "hardware/runtime assumptions change",
      "GitHub workflow changes",
      "dependency automation changes"
    ]
  }
}
